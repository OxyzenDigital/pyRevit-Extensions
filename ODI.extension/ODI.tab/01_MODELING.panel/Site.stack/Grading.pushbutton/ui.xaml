<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toposolid Grading Tool" Height="930" Width="420"
        WindowStartupLocation="Manual" Left="250" Top="100"
        ResizeMode="CanResize"
        WindowStyle="None"
        Foreground="{DynamicResource TextBrush}"
        BorderBrush="{DynamicResource AccentBrush}"
        BorderThickness="1"
        Background="{DynamicResource WindowBrush}">
    <Window.Resources>
        <!-- ── Light-theme defaults (overridden in code for Dark theme) ── -->
        <SolidColorBrush x:Key="WindowBrush"        Color="#F4F4F4"/>
        <SolidColorBrush x:Key="ControlBrush"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush"          Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextLightBrush"     Color="#767676"/>
        <SolidColorBrush x:Key="AccentBrush"        Color="#0078D4"/>
        <SolidColorBrush x:Key="HeaderTextBrush"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HeaderSubTextBrush" Color="#CCE4FF"/>
        <SolidColorBrush x:Key="BorderBrush"        Color="#D6D6D6"/>
        <SolidColorBrush x:Key="StatusReadyBrush"   Color="#107C10"/>
        <SolidColorBrush x:Key="StatusErrorBrush"   Color="#C50F1F"/>
        <SolidColorBrush x:Key="ButtonBrush"        Color="#F0F0F0"/>
        <SolidColorBrush x:Key="HoverBrush"         Color="#E1EFFF"/>
        <SolidColorBrush x:Key="PressedBrush"       Color="#C7E0FF"/>
        <SolidColorBrush x:Key="RowUnsetBrush"      Color="#F8F8F8"/>
        <SolidColorBrush x:Key="RowSetBrush"        Color="#F0FFF0"/>
        <SolidColorBrush x:Key="DotUnsetBrush"      Color="#BBBBBB"/>
        <SolidColorBrush x:Key="DotSetBrush"        Color="#107C10"/>
        <SolidColorBrush x:Key="DotBusyBrush"       Color="#FF8C00"/>

        <!-- ── Default Button style ── -->
        <Style TargetType="Button">
            <Setter Property="Background"   Value="{DynamicResource ButtonBrush}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,3"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent (primary action) Button style ── -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Misc element styles ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"     Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground"     Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="4,2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"  Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style TargetType="RadioButton"> <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/> </Style>
        <Style TargetType="CheckBox">    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/> </Style>
        <Style TargetType="Label">       <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/> </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Margin"     Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header            -->
            <RowDefinition Height="Auto"/>  <!-- 1: Selections        -->
            <RowDefinition Height="Auto"/>  <!-- 2: Method            -->
            <RowDefinition Height="Auto"/>  <!-- 3: Parameters        -->
            <RowDefinition Height="*"/>     <!-- 4: Spacer            -->
            <RowDefinition Height="Auto"/>  <!-- 5: Options + Actions -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════
             ROW 0 — Draggable header with live status dot
             ═══════════════════════════════════════════════ -->
        <Border Name="HeaderDrag" Grid.Row="0"
                Background="{DynamicResource AccentBrush}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- status dot -->
                    <ColumnDefinition Width="*"/>      <!-- title      -->
                    <ColumnDefinition Width="Auto"/>   <!-- close btn  -->
                </Grid.ColumnDefinitions>

                <!-- Live status dot: green=ready, amber=selecting/busy, red=error -->
                <Ellipse Name="Dot_Status" Grid.Column="0"
                         Width="10" Height="10" Fill="#55DD55"
                         Margin="0,0,10,0" VerticalAlignment="Center"
                         ToolTip="Tool status indicator"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Grading Assistant"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTextBrush}"/>
                    <!-- Updated live by set_status() to show current activity -->
                    <TextBlock Name="Tb_StatusHeader"
                               Text="Slope Control &amp; Edge Repair"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{DynamicResource HeaderSubTextBrush}"/>
                </StackPanel>

                <Button Name="Btn_WinClose" Grid.Column="2"
                        Content="✕" Width="28" Height="28"
                        Foreground="White" Background="Transparent"
                        BorderThickness="0" FontSize="14" FontWeight="Bold"
                        Cursor="Hand" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Name="cb" Background="{TemplateBinding Background}" CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="cb" Property="Background" Value="#44FFFFFF"/>
                                    <Setter Property="Foreground" Value="#FF8888"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════
             ROW 1 — Selections  (stakes + line + recipe)
             Each row shows a colored dot (● unset / ✓ set)
             and the selected element label beside it.
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,8,12,4">
            <GroupBox Header="1. Selections" Padding="10"
                      Background="{DynamicResource ControlBrush}"
                      BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>

                    <!-- Start Stake indicator row -->
                    <Border Name="Row_StartStake" CornerRadius="3" Margin="0,0,0,3" Padding="7,5"
                            Background="{DynamicResource RowUnsetBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Name="Dot_StartStake" Width="9" Height="9"
                                     Fill="{DynamicResource DotUnsetBrush}" VerticalAlignment="Center"
                                     ToolTip="Start Stake selection state"/>
                            <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                <TextBlock Text="Start Stake" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Name="Lb_StartStake" Text="[None selected]"
                                           FontSize="10" Foreground="{DynamicResource TextLightBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- End Stake indicator row -->
                    <Border Name="Row_EndStake" CornerRadius="3" Margin="0,0,0,3" Padding="7,5"
                            Background="{DynamicResource RowUnsetBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Name="Dot_EndStake" Width="9" Height="9"
                                     Fill="{DynamicResource DotUnsetBrush}" VerticalAlignment="Center"
                                     ToolTip="End Stake selection state"/>
                            <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                <TextBlock Text="End Stake" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Name="Lb_EndStake" Text="[None selected]"
                                           FontSize="10" Foreground="{DynamicResource TextLightBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Guide Line indicator row -->
                    <Border Name="Row_Line" CornerRadius="3" Margin="0,0,0,6" Padding="7,5"
                            Background="{DynamicResource RowUnsetBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Name="Dot_Line" Width="9" Height="9"
                                     Fill="{DynamicResource DotUnsetBrush}" VerticalAlignment="Center"
                                     ToolTip="Guide Line selection state"/>
                            <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                <TextBlock Text="Guide Line" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Name="Lb_Line" Text="[None selected]"
                                           FontSize="10" Foreground="{DynamicResource TextLightBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Calculated slope badge (updates when both stakes are set) -->
                    <TextBlock Name="Lb_CalculatedSlope" Text="Slope: —"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="7,0,0,8"/>

                    <!-- Selection action buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>
                        <Button Name="Btn_SelectStakes" Content="Pick Stakes"
                                Height="27" Grid.Column="0" Margin="0,0,4,0"
                                ToolTip="Pick Start Stake then End Stake in the model. &#10;The tool stays open while you select."/>
                        <Button Name="Btn_SelectLine" Content="Pick Line"
                                Height="27" Grid.Column="1" Margin="0,0,4,0"
                                ToolTip="Pick the Guide Line (Model Line or Detail Line) in the model. &#10;The tool stays open while you select."/>
                        <Button Name="Btn_Swap" Content="⇄" Height="27" Grid.Column="2"
                                IsEnabled="False" FontSize="14"
                                ToolTip="Swap Start Stake and End Stake (reverses grading direction)"/>
                    </Grid>

                    <!-- Load Recipe divider -->
                    <Separator Margin="0,8,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Recall settings from a previously graded Toposolid:"
                                   FontSize="10" Foreground="{DynamicResource TextLightBrush}"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Name="Btn_ReadRecipe" Content="Load Recipe" Grid.Column="1"
                                Width="92" Height="22" FontSize="10" Margin="8,0,0,0"
                                ToolTip="Select a Toposolid that has been graded before to restore its settings."/>
                    </Grid>

                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════════════════════════════
             ROW 2 — Calculation method
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="12,0,12,4">
            <GroupBox Header="2. Calculation Method" Padding="10"
                      Background="{DynamicResource ControlBrush}"
                      BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Name="Rb_MatchStakes" Content="Match Stakes"
                                     GroupName="Method" IsChecked="True" Margin="0,0,20,0"
                                     ToolTip="Derive slope from the elevation difference between the two stakes."/>
                        <RadioButton Name="Rb_UseSlope" Content="Use Slope %"
                                     GroupName="Method"
                                     ToolTip="Apply a fixed slope % from the Start Stake downslope."/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Slope:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Name="Tb_Slope" Text="2.0" Grid.Column="1"
                                 VerticalContentAlignment="Center" IsEnabled="False"
                                 ToolTip="Slope as a percentage. Positive = rising away from Start Stake."/>
                        <TextBlock Text="%" Grid.Column="2" VerticalAlignment="Center"
                                   Margin="4,0,0,0" Foreground="{DynamicResource TextLightBrush}"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════════════════════════════
             ROW 3 — Parameters (width, falloff, grid)
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Margin="12,0,12,4">
            <GroupBox Header="3. Parameters" Padding="10"
                      Background="{DynamicResource ControlBrush}"
                      BorderBrush="{DynamicResource BorderBrush}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Path Width:"      VerticalAlignment="Center" Grid.Row="0"/>
                        <TextBox Name="Tb_Width"   Text="6.0"  Grid.Row="0" Grid.Column="1"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Full width of the graded path (centre-to-centre of edge points)."/>
                        <TextBlock Name="Lbl_Width_Unit"  Text="ft" Grid.Row="0" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextLightBrush}"/>

                        <TextBlock Text="Falloff Distance:" VerticalAlignment="Center" Grid.Row="1"/>
                        <TextBox Name="Tb_Falloff" Text="10.0" Grid.Row="1" Grid.Column="1"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Distance beyond the path edge over which the terrain blends back to existing grade. 0 = no blend."/>
                        <TextBlock Name="Lbl_Falloff_Unit" Text="ft" Grid.Row="1" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextLightBrush}"/>

                        <TextBlock Text="Grid Resolution:"  VerticalAlignment="Center" Grid.Row="2"/>
                        <TextBox Name="Tb_Grid"    Text="3.0"  Grid.Row="2" Grid.Column="1"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Spacing between generated toposolid points. Smaller = smoother but slower."/>
                        <TextBlock Name="Lbl_Grid_Unit"   Text="ft" Grid.Row="2" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextLightBrush}"/>

                        <TextBlock Text="Outlier Tol:"  VerticalAlignment="Center" Grid.Row="3"/>
                        <TextBox Name="Tb_OutlierTol"    Text="1.0"  Grid.Row="3" Grid.Column="1"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Height difference threshold to delete outlier points before smoothing."/>
                        <TextBlock Name="Lbl_OutlierTol_Unit"   Text="ft" Grid.Row="3" Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextLightBrush}"/>
                    </Grid>
                    <Separator/>
                    <CheckBox Name="Cb_SquareEnds"
                              Content="Square Ends  (stop grading orthogonally at line ends)"
                              Margin="0,4,0,0" IsChecked="False"
                              ToolTip="If checked, grading stops at a flat plane perpendicular to the guide line at each end, &#10;rather than fading out radially beyond the endpoints."/>
                    <CheckBox Name="Cb_SharpSmoothing"
                              Content="Sharp Smoothing (ignore falloff for Smooth Path)"
                              Margin="0,4,0,0" IsChecked="False"
                              ToolTip="If checked, the 'Smooth Path' operation only affects points strictly within the Path Width, keeping edges sharp by ignoring the Falloff distance."/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ROW 4 — flexible spacer keeps actions pinned to bottom -->

        <!-- ═══════════════════════════════════════════════
             ROW 5 — Options, Status bar, and Actions
             ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="5" Margin="12,0,12,12">
            <StackPanel>

                <!-- Options row -->
                <GroupBox Header="4. Options" Padding="10" Margin="0,0,0,8"
                          Background="{DynamicResource ControlBrush}"
                          BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="Cb_ResetPoints" Content="Reset existing points" Grid.Column="0"
                                      VerticalAlignment="Center" ToolTip="Remove existing toposolid points inside the grading zone before adding new ones."/>
                            <CheckBox Name="Cb_Triangulate" Content="Add Split Lines" Grid.Column="1"
                                      VerticalAlignment="Center" ToolTip="Draw split lines perpendicular to the path to enforce uniform triangulation."/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="Cb_ApplyOffset" Content="Z-Offset:" Grid.Column="0"
                                      VerticalAlignment="Center" ToolTip="Apply a fixed vertical offset to all generated points."/>
                            <TextBox Name="Tb_Offset" Text="0.0" Grid.Column="1" Height="22"
                                     VerticalContentAlignment="Center"
                                     IsEnabled="{Binding ElementName=Cb_ApplyOffset, Path=IsChecked}"/>
                            <TextBlock Name="Lbl_Offset_Unit" Text="ft" Grid.Column="2"
                                       VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{DynamicResource TextLightBrush}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Name="Cb_PlanOffset" Content="Plan Offset:" Grid.Column="0"
                                      VerticalAlignment="Center" ToolTip="Offset graded points horizontally from the line."/>
                            <TextBox Name="Tb_PlanOffset" Text="0.0" Grid.Column="1" Height="22"
                                     VerticalContentAlignment="Center"
                                     IsEnabled="{Binding ElementName=Cb_PlanOffset, Path=IsChecked}"/>
                            <ComboBox Name="Cmb_PlanOffsetDir" Grid.Column="2" Height="22" Margin="4,0,0,0"
                                      IsEnabled="{Binding ElementName=Cb_PlanOffset, Path=IsChecked}"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Center"/>
                                <ComboBoxItem Content="Left"/>
                                <ComboBoxItem Content="Right"/>
                                <ComboBoxItem Content="Both" IsSelected="True"/>
                            </ComboBox>
                            <TextBlock Name="Lbl_PlanOffset_Unit" Text="ft" Grid.Column="3"
                                       VerticalAlignment="Center" Margin="4,0,0,0" Foreground="{DynamicResource TextLightBrush}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Status bar — colour and text driven by set_status() in code -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="3" Padding="8,5" Margin="0,0,0,8"
                        Background="{DynamicResource ControlBrush}">
                    <Label Name="Lb_Status"
                           Content="Modeless — select inputs, then click an action button."
                           HorizontalContentAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}"
                           Padding="0" FontSize="11"/>
                </Border>

                <!-- PRIMARY actions -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Name="Btn_Run"    Content="Sculpt Terrain" Height="42"
                            Grid.Column="0"  Margin="0,0,4,0"
                            Style="{StaticResource AccentButton}" FontSize="13"
                            IsEnabled="False"
                            ToolTip="Generate a dense grid of graded toposolid points along the Guide Line between the two Stakes."/>
                    <Button Name="Btn_Edging" Content="Run Edging"     Height="42"
                            Grid.Column="1"  Margin="0,0,0,0"
                            FontWeight="SemiBold" IsEnabled="False"
                            ToolTip="Place precise elevation points along the left and right edges of the graded path."/>
                </Grid>

                <!-- SECONDARY actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button Name="Btn_Stitch"     Content="Stitch Edge"         Height="30"
                            Grid.Row="0" Grid.Column="0" Margin="0,0,4,4"
                            ToolTip="Snap internal toposolid points to the nearest boundary edge to close gaps."/>
                    <Button Name="Btn_LinePoints" Content="Grade with Elements" Height="30"
                            Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                            ToolTip="Add toposolid points along a Model Line or Filled Region at their own elevation."/>
                    <Button Name="Btn_SmoothRegion" Content="Smooth Region"     Height="30"
                            Grid.Row="1" Grid.Column="0" Margin="0,0,4,0"
                            ToolTip="Select a Toposolid and a Filled Region to apply Laplacian smoothing to the interior points."/>
                    <Button Name="Btn_SmoothPath"   Content="Smooth Path"       Height="30"
                            Grid.Row="1" Grid.Column="1" Margin="0,0,0,0"
                            ToolTip="Select a Toposolid and a Guide Line to apply Laplacian smoothing along the path using the Path Width."/>
                </Grid>

            </StackPanel>
        </Grid>
    </Grid>
</Window>