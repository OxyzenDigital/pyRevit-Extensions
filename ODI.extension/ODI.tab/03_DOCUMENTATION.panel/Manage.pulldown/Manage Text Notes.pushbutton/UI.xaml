<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Text Notes" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ToolbarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
        
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#EBF8FF"/>
        <SolidColorBrush x:Key="SelectionBorderBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="SelectionTextBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CheckedBrush" Color="#DBEAFE"/>
        <SolidColorBrush x:Key="CheckedTextBrush" Color="#1E3A8A"/>
        <SolidColorBrush x:Key="TracedBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TracedBorderBrush" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="TracedTextBrush" Color="#111827"/>
        
        <!-- Button Styles -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="{DynamicResource WindowBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tree View Inline Editor Styles -->
        <Style TargetType="Grid" x:Key="DisplayGridStyle">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Grid" x:Key="EditGridStyle">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource WindowBrush}">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Header -->
        <Border x:Name="HeaderDrag" Grid.Row="0" Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="15,10" Cursor="SizeAll">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Manage Text Notes" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource HeaderTextBrush}"/>
                    <TextBlock Text=" | Standardization" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
                <!-- Close Button -->
                <Button x:Name="Btn_WinClose" Grid.Column="1" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Content>
                        <TextBlock Text="✕" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>

        <!-- Toolbar Left -->
        <Border Grid.Row="1" Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="15,8">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Name="Btn_ScanActive" Content="Scan Active" Margin="0,0,10,0" Padding="12,4"/>
                    <Button Name="Btn_ScanProject" Content="Scan Project" Margin="0,0,20,0" Padding="12,4"/>
                    <CheckBox x:Name="Cb_AutoZoom" Content="Auto Zoom to Selected Note" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Split Content -->
        <Grid Grid.Row="2" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- Pane 1: Tree View -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                    <TreeView x:Name="systemTree" Margin="5" ItemsSource="{Binding Sheets}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="19"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" VerticalAlignment="Center">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent" Height="16" Padding="5" Width="16">
                                                                <Path x:Name="ExpandPath" Data="M0,0 L0,6 L6,0 z" Fill="{DynamicResource TextLightBrush}" Stroke="{DynamicResource TextLightBrush}">
                                                                    <Path.RenderTransform>
                                                                        <RotateTransform Angle="135" CenterX="3" CenterY="3"/>
                                                                    </Path.RenderTransform>
                                                                </Path>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter Property="RenderTransform" TargetName="ExpandPath"><Setter.Value><RotateTransform Angle="180" CenterX="3" CenterY="3"/></Setter.Value></Setter>
                                                                    <Setter Property="Fill" TargetName="ExpandPath" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Stroke" TargetName="ExpandPath" Value="{DynamicResource AccentBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <Border x:Name="Bd" Grid.Column="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost" Grid.Column="1" Grid.Row="1"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="False"><Setter Property="Visibility" TargetName="ItemsHost" Value="Collapsed"/></Trigger>
                                                <Trigger Property="HasItems" Value="False"><Setter Property="Visibility" TargetName="Expander" Value="Hidden"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Border BorderThickness="1" CornerRadius="4" Margin="0,2,4,2" Padding="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsTraced}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource TracedBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource TracedBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsThreeState="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="{Binding FontWeight}" VerticalAlignment="Center" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTraced}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource TracedTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding NoteCount, StringFormat=' ({0})'}" Foreground="{DynamicResource TextLightBrush}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
                <Border Grid.Row="1" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8,6" CornerRadius="0,0,4,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Name="Btn_SelectAll" Content="Select All" IsEnabled="{Binding CanTreeSelectAll}" Margin="0,0,5,0" Padding="8,2" FontSize="11"/>
                        <Button Name="Btn_SelectNone" Content="Select None" IsEnabled="{Binding CanTreeSelectNone}" Margin="0,0,5,0" Padding="8,2" FontSize="11"/>
                        <Button Name="Btn_ExpandAll" Content="Expand All" IsEnabled="{Binding CanTreeExpandAll}" Margin="0,0,5,0" Padding="8,2" FontSize="11"/>
                        <Button Name="Btn_CollapseAll" Content="Collapse All" IsEnabled="{Binding CanTreeCollapseAll}" Padding="8,2" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" ToolTip="Drag to resize panes"/>

            <!-- Pane 2: Project Notes Data Grid -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Current Project Notes" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Name="Btn_ExportNew" Content="Export Selected to New File" Padding="8,2" FontSize="11" Margin="0,0,5,0" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
                        <Button Name="Btn_AppendProject" Content="Append Selected to Notes File" Padding="8,2" FontSize="11" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
                    </StackPanel>
                </Grid>
                
                <DataGrid x:Name="Grid_Notes" Grid.Row="1" ItemsSource="{Binding CurrentNotes}" 
                          RowHeaderWidth="0" VerticalScrollBarVisibility="Auto" SelectionMode="Extended">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="IsSelected" Value="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Setter Property="Background" Value="{DynamicResource WindowBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E3A8A"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="View" Binding="{Binding FormattedViewName}" IsReadOnly="True" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="{Binding ViewName}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Content" Binding="{Binding Text}" IsReadOnly="True" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style>
                                    <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="▶" ToolTip="Append to Canvas" Click="BtnAppendSingleNote_Click" Padding="4,2" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE" ToolTip="Drag to resize panes"/>

            <!-- Pane 3: Master Notes Editor -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Master Notes Toolbar -->
                <Border Grid.Row="0" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Notes File Editor" ToolTip="{Binding FilePath}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <Button Name="Btn_ClearCanvas" Content="Clear Canvas" Padding="8,2" Margin="0,0,5,0"/>
                            <Button Name="Btn_PickFile" Content="Locate File" Padding="8,2" Margin="0,0,5,0"/>
                            <Button Name="Btn_SaveFile" Content="Save" Padding="8,2" Margin="0,0,5,0"/>
                            <Button Name="Btn_SaveAsFile" Content="Save As..." Padding="8,2" Margin="0,0,10,0"/>
                            <Button Name="Btn_AddNote" Content="+ Root Note" ToolTip="Add a new note to the top of the file" Padding="8,2" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="File:" Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding FilePath}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" FontStyle="Italic" MaxWidth="150" TextTrimming="CharacterEllipsis" Margin="0,0,15,0"/>
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}"/>
                            <TextBox x:Name="Tb_Search" Width="150" Text="{Binding MasterSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" Background="{DynamicResource WindowBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Master Notes Tree -->
                <Border Grid.Row="1" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                    <TreeView x:Name="Tree_Master" Margin="5" ItemsSource="{Binding MasterTree}" SelectedItemChanged="Tree_Master_SelectedItemChanged" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <Border BorderThickness="1" CornerRadius="4" Margin="0,2,0,2" Padding="0" HorizontalAlignment="Left" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="5,0,35,0">
                                        <!-- Project Node Template -->
                                        <Border Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="Project">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Children.Count, StringFormat=' ({0})'}" Foreground="{DynamicResource TextLightBrush}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <!-- Master Note Template -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NodeType}" Value="MasterNote">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <!-- Read Mode -->
                                            <Grid Style="{StaticResource DisplayGridStyle}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Text}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,0,0">
                                                    <Button Content="✎" ToolTip="Edit Note" Click="BtnEditNote_Click" Margin="0,0,5,0" Padding="8,2" FontSize="11" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
                                                    <Button Content="◀" ToolTip="Replace with Selected Note" Click="BtnReplaceNotes_Click" IsEnabled="{Binding DataContext.CanReplaceSelected, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,5,0" Padding="8,2" FontSize="11" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                                                    <Button Content="-" ToolTip="Delete Note" Click="BtnDeleteNote_Click" Margin="0,0,5,0" Padding="8,2" FontSize="11" Background="#FEE2E2" Foreground="#991B1B" BorderThickness="0" FontWeight="Bold"/>
                                                    <Button Content="+" ToolTip="Add Note Below" Click="BtnAddNoteBelow_Click" Padding="8,2" FontSize="11" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Edit Mode -->
                                            <Grid Style="{StaticResource EditGridStyle}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Padding="4" Background="{DynamicResource WindowBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"/>
                                                <StackPanel Grid.Column="1" Margin="10,0,15,0" VerticalAlignment="Top">
                                                    <Button Content="Done" Click="BtnDoneEdit_Click" Padding="8,4" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                                    <Button Content="UPPER" Click="BtnCaseUpper_Click" Padding="8,2" FontSize="10" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"/>
                                                    <Button Content="lower" Click="BtnCaseLower_Click" Padding="8,2" FontSize="10" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"/>
                                                    <Button Content="Title" Click="BtnCaseTitle_Click" Padding="8,2" FontSize="10" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <!-- Right Pane Footer Actions -->
                <Border Grid.Row="2" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8,6" CornerRadius="0,0,4,4" Margin="0,2,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Name="Btn_MasterExpandAll" Content="Expand All" IsEnabled="{Binding CanMasterExpandAll}" Margin="0,0,2.5,0" Padding="8,2" FontSize="11"/>
                        <Button Grid.Column="1" Name="Btn_MasterCollapseAll" Content="Collapse All" IsEnabled="{Binding CanMasterCollapseAll}" Margin="2.5,0,0,0" Padding="8,2" FontSize="11"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="3" Background="{DynamicResource ToolbarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15">
            <Grid>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource TextLightBrush}"/>
            </Grid>
        </Border>
        </Grid>
    </Border>
</Window>
