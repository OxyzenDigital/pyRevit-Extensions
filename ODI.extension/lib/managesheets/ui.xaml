<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Quantify & Measure Exact Color Schema -->
        <SolidColorBrush x:Key="WindowBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="ToolbarBrush" Color="#EBF4FA"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#888888"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D7"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#CCE8FF"/>
        <SolidColorBrush x:Key="SelectionBorderBrush" Color="#0078D7"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="FooterBrush" Color="#EFEFEF"/>
        <SolidColorBrush x:Key="AltRowBrush" Color="#FAFAFA"/>

        <SolidColorBrush x:Key="CardBorderBrush" Color="#DCDCDC"/>
        <SolidColorBrush x:Key="SelectionTextBrush" Color="Black"/>
        <SolidColorBrush x:Key="InactiveSelectionBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="CardTextBrush" Color="#000000"/>
        <SolidColorBrush x:Key="CardSubTextBrush" Color="#666666"/>
        <SolidColorBrush x:Key="CardLabelBrush" Color="#888888"/>
        <SolidColorBrush x:Key="CardValueBrush" Color="#000000"/>
        <SolidColorBrush x:Key="CardAccentBrush" Color="#0078D7"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FEE2E2"/>
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#991B1B"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#DCFCE7"/>
        <SolidColorBrush x:Key="SuccessTextBrush" Color="#166534"/>
        <SolidColorBrush x:Key="UpdateBrush" Color="#FEF3C7"/>
        <SolidColorBrush x:Key="UpdateTextBrush" Color="#92400E"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="DarkGridTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style x:Key="DarkGridTextLightStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>

        <Style x:Key="BaseGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource ButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border Name="Border" Background="{DynamicResource WindowBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,1,0" Padding="15,8" Margin="0,0,2,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ControlBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <ControlTemplate TargetType="{x:Type ToggleButton}" x:Key="ComboBoxToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="0" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" />
                <Border Grid.Column="0" CornerRadius="0" Margin="1" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="{DynamicResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>

        <ControlTemplate TargetType="{x:Type TextBox}" x:Key="ComboBoxTextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}" />
        </ControlTemplate>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="3,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Template="{StaticResource ComboBoxTextBox}" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,3,23,3" Focusable="True" Background="Transparent" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource ControlBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"/>
                                    <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="true">
                                <Setter Property="IsTabStop" Value="false"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource InactiveSelectionBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ToolbarBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <!-- Base TreeView Item Style (From Quantify) -->
        <Style TargetType="{x:Type TreeViewItem}" x:Key="BaseTreeItemStyle">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="19"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" VerticalAlignment="Center">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent" Height="16" Padding="5" Width="16">
                                            <Path x:Name="ExpandPath" Data="M0,0 L0,6 L6,0 z" Fill="{DynamicResource TextLightBrush}" Stroke="{DynamicResource TextLightBrush}">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="135" CenterX="3" CenterY="3"/>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="RenderTransform" TargetName="ExpandPath">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" CenterX="3" CenterY="3"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Fill" TargetName="ExpandPath" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Stroke" TargetName="ExpandPath" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border x:Name="Bd" Grid.Column="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                <ContentPresenter x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Column="1" Grid.Row="1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False"><Setter Property="Visibility" TargetName="ItemsHost" Value="Collapsed"/></Trigger>
                            <Trigger Property="HasItems" Value="False"><Setter Property="Visibility" TargetName="Expander" Value="Hidden"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource BaseTreeItemStyle}"/>
        <Style TargetType="{x:Type TreeViewItem}" x:Key="TargetSchemaTreeItemStyle" BasedOn="{StaticResource BaseTreeItemStyle}">
            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
        </Style>

        <!-- Read/Edit Toggle Styles -->
        <Style TargetType="{x:Type Grid}" x:Key="DisplayGridStyle">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type Grid}" x:Key="EditGridStyle">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Name="Bg" SnapsToDevicePixels="true">
                            <Border Background="{DynamicResource ControlBrush}" Opacity="0.5" />
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="{DynamicResource HoverBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Margin="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvisibleThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource WindowBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="{DynamicResource ToolbarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- We bind MouseLeftButtonDown in code-behind -->
                <Border Name="TitleBarGrid" Grid.Column="0" Background="Transparent">
                    <TextBlock Text="Manage Sheets" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Border>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Name="Btn_MinimizeWindow" Content="-" Width="30" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}" FontSize="16" Cursor="Hand"/>
                    <Button Name="Btn_CloseWindow" Content="✕" Width="30" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}" FontSize="14" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- Main TabControl -->
            <TabControl Name="MainTabControl" Grid.Row="1" Background="{DynamicResource WindowBrush}" BorderThickness="0" Margin="10">
                
                <!-- TAB 1: PROJECT SETUP -->
                <TabItem Header="Project Setup">
                    <Grid Background="{DynamicResource ControlBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Generated Target Schema Viewer -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="Transparent" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CAD Standard Schema" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <CheckBox Name="Tgl_ShowExcluded" Content="Show Excluded" Foreground="{DynamicResource TextLightBrush}" IsChecked="False" VerticalAlignment="Center" FontSize="11" ToolTip="Show or hide manually excluded schema sheets" Margin="0,0,5,0"/>
                                        <CheckBox Name="Chk_ShuffleOnExclude" Content="Shuffle on Exclude" Foreground="{DynamicResource TextLightBrush}" IsChecked="False" VerticalAlignment="Center" FontSize="11" ToolTip="Shuffle generated sheet numbers to close gaps when a sheet is excluded"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBox Name="Txt_SearchSchema" Grid.Row="1" Margin="5" Padding="2" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBrush}"/>
                            <TreeView Name="TargetSchemaTree" Grid.Row="2" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource BorderBrush}" Padding="5" ItemContainerStyle="{StaticResource TargetSchemaTreeItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="0,2" Opacity="{Binding TargetOpacity}">
                                            <CheckBox IsChecked="{Binding IsTargetIncluded, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,5,0" ToolTip="Include/Exclude this sheet from the project setup"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="{Binding FontWeight}" VerticalAlignment="Center" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextDecorations" Value="None"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTargetIncluded}" Value="False">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DisplayCount}" Foreground="{DynamicResource TextLightBrush}" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                            <Border Grid.Row="3" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,1,0" Padding="5">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Name="Btn_ExpandSchema" Content="Expand All" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="11" Padding="5,2"/>
                                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" VerticalAlignment="Center" Margin="5,0"/>
                                    <Button Name="Btn_CollapseSchema" Content="Collapse All" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="11" Padding="5,2"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

                        <!-- RIGHT: Settings Input -->
                        <Grid Grid.Column="2" Background="{DynamicResource WindowBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="20,20,20,10">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="AIA Configuration Settings" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                    <StackPanel Name="AutoRefreshWarningPanel" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Visibility="Collapsed">
                                        <Button Name="Btn_RefreshData" Content="↻ Load/Refresh Revit Data" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Bold" Padding="10,5" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right"/>
                                        <TextBlock Text="Large project (>150 sheets). Auto-refresh paused. Click to manually load." Foreground="{DynamicResource ErrorBrush}" FontSize="10" Margin="0,2,0,0" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Check your selections and return to the Sheet Reviewer to map existing sheets." Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,20" TextWrapping="Wrap"/>
                                
                                <!-- 1. GENERAL SETTINGS (Top Group Box) -->
                                <Border BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="4" Padding="10" Background="{DynamicResource ControlBrush}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="1. General Settings" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 0: Scheme & Cover -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="Naming Scheme:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}"/>
                                                <ComboBox Name="Cmb_NamingScheme" IsEditable="True" Width="200" VerticalAlignment="Center"/>
                                                <Button Name="Btn_EditNamingSchemes" Content="⚙ Edit" Width="50" Height="22" Margin="5,0,20,0" ToolTip="Edit Naming Schemes for this project"/>
                                                
                                                <CheckBox Name="Chk_GlobalCover" Content="Generate single Global Cover/General set (CS)" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" ToolTip="When checked, generates exactly 3 global CS-000 series sheets instead of duplicating them per discipline."/>
                                            </StackPanel>

                                            <!-- Row 1: Enlargement Grid Size -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                                <TextBlock Text="Enlargement Grid:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="Rows:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}"/>
                                                <Slider Name="Sld_GridRows" Minimum="1" Maximum="10" Value="1" Width="80" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                <TextBox Name="Txt_GridRows" Text="{Binding ElementName=Sld_GridRows, Path=Value, UpdateSourceTrigger=PropertyChanged}" Width="30" Margin="5,0,15,0" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                                
                                                <TextBlock Text="Cols:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextBrush}"/>
                                                <Slider Name="Sld_GridCols" Minimum="1" Maximum="10" Value="1" Width="80" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                                <TextBox Name="Txt_GridCols" Text="{Binding ElementName=Sld_GridCols, Path=Value, UpdateSourceTrigger=PropertyChanged}" Width="30" Margin="5,0,10,0" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                                
                                                <TextBlock Text="(Default 1x1 disables enlargement suffixes like NW, NE, etc.)" VerticalAlignment="Center" Foreground="{DynamicResource TextLightBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="20,0,20,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>
                                <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>
                                <GridSplitter Grid.Column="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>

                                <!-- 2. LEVELS -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="2. Building Levels" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                                        <Button Name="Btn_LevelAll" Content="Select All" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                        <Button Name="Btn_LevelNone" Content="Select None" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                    <TextBox Name="Txt_SearchLevels" Grid.Row="2" Margin="0,0,0,5" Padding="2" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBrush}"/>
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource ControlBrush}">
                                        <ListBox Name="List_Levels" BorderThickness="0" Background="Transparent" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ListBoxItem}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="5" Foreground="{DynamicResource TextBrush}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Grid>

                                <!-- 3. DISCIPLINES -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="3. Disciplines" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                                        <Button Name="Btn_DiscAll" Content="Select All" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                        <Button Name="Btn_DiscNone" Content="Select None" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                    <TextBox Name="Txt_SearchDisciplines" Grid.Row="2" Margin="0,0,0,5" Padding="2" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBrush}"/>
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource ControlBrush}">
                                        <ListBox Name="List_Disciplines" BorderThickness="0" Background="Transparent" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ListBoxItem}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="5" Foreground="{DynamicResource TextBrush}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Grid>

                                <!-- 4. SHEET SERIES -->
                                <Grid Grid.Column="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="4. Sheet Series" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                                        <Button Name="Btn_SeriesAll" Content="Select All" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                        <Button Name="Btn_SeriesNone" Content="Select None" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                    <TextBox Name="Txt_SearchSeries" Grid.Row="2" Margin="0,0,0,5" Padding="2" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBrush}"/>
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource ControlBrush}">
                                        <ListBox Name="List_Series" BorderThickness="0" Background="Transparent" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ListBoxItem}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="5" Foreground="{DynamicResource TextBrush}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Grid>

                                <!-- 5. NAME MODIFIERS -->
                                <Grid Grid.Column="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="5. Name Modifiers" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                        <Button Name="Btn_EditModifiers" Grid.Column="1" Content="⚙ Edit" Width="50" Height="22" Margin="5,0,0,0" ToolTip="Edit Classification &amp; Modifiers for this project"/>
                                    </Grid>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                                        <Button Name="Btn_ModAll" Content="Select All" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                        <Button Name="Btn_ModNone" Content="Select None" Padding="5,2" FontSize="10" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                    <TextBox Name="Txt_SearchModifiers" Grid.Row="2" Margin="0,0,0,5" Padding="2" Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBrush}"/>
                                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Background="{DynamicResource ControlBrush}" Margin="0">
                                        <TreeView Name="Tree_Modifiers" Background="Transparent" BorderThickness="0" Padding="2" ItemContainerStyle="{StaticResource BaseTreeItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <StackPanel Orientation="Horizontal" Margin="0,2" IsEnabled="{Binding IsEnabled}">
                                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsThreeState="{Binding IsThreeState}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding Name}" FontWeight="{Binding FontWeight}" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Text="{Binding DisplayCount}" Foreground="{DynamicResource TextLightBrush}" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                    </Border>
                                    <Border Grid.Row="4" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Padding="5" Margin="0,0,0,5">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Name="Btn_ExpandModifiers" Content="Expand All" Padding="5,2" FontSize="11" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" VerticalAlignment="Center" Margin="5,0"/>
                                            <Button Name="Btn_CollapseModifiers" Content="Collapse All" Padding="5,2" FontSize="11" Background="Transparent" Foreground="{DynamicResource AccentBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

            
<!-- TAB 2: SHEET REVIEWER -->
                <TabItem Header="Sheet Reviewer">
                    <Grid Background="{DynamicResource ControlBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT PANE: Navigation Tree -->
                        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="Transparent" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <TextBlock Text="Model Collections &amp; Sheets" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </Border>
                                
                                <TreeView Name="NavTree" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <TextBlock Text="{Binding Name}" FontWeight="{Binding FontWeight}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DisplayCount}" Foreground="{DynamicResource TextLightBrush}" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center" Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                                
                                <!-- Nav Footer Actions -->
                                <Border Grid.Row="2" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="5">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Name="Btn_ExpandNav" Content="Expand All" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="11" Padding="5,2"/>
                                        <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" VerticalAlignment="Center" Margin="5,0"/>
                                        <Button Name="Btn_CollapseNav" Content="Collapse All" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="11" Padding="5,2"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

                        <!-- RIGHT PANE: Card Grid Editor -->
                        <Grid Grid.Column="2" Background="{DynamicResource WindowBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Border Grid.Row="0" Background="{DynamicResource ToolbarBrush}" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Name="Txt_GridTitle" Text="Select an item in the navigation tree..." FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Name="Btn_SaveProjectSettings" Content="💾 Save to Project" Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="5,0,0,0"/>
                                        <Button Name="Btn_ClearProjectSettings" Content="🗑 Clear Schema" Background="Transparent" Foreground="{DynamicResource ErrorTextBrush}" BorderThickness="1" BorderBrush="{DynamicResource ErrorBrush}" Margin="5,0,0,0"/>
                                        <Button Name="Btn_ResetAll" Content="⎌ Reset All" Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="5,0,0,0"/>
                                        <Button Name="Btn_AddMissing" Content="+ Add Missing Schema Sheets" Background="{DynamicResource ControlBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                        <Button Name="Btn_RunMatch" Content="Run Schema Match" FontWeight="Bold" Background="{DynamicResource AccentBrush}" Foreground="White" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- DataGrid replacing ListBox and Fake Header -->
                            <DataGrid Name="EditorGrid" Grid.Row="1" Grid.RowSpan="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}" Background="Transparent" BorderThickness="0" RowBackground="{DynamicResource WindowBrush}" AlternatingRowBackground="{DynamicResource AltRowBrush}" EnableRowVirtualization="False" CellStyle="{StaticResource BaseGridCell}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="{x:Type DataGridRow}">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource InactiveSelectionBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding Action}" Value="PURGE">
                                                <Setter Property="Opacity" Value="0.5"/>
                                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Action}" Value="CREATE">
                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Action}" Value="UPDATE">
                                                <Setter Property="Background" Value="{DynamicResource UpdateBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Sync" Width="40">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Action}" IsReadOnly="True" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource DarkGridTextStyle}">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    
                                    <DataGridTextColumn Header="Type" Binding="{Binding CollectionName}" IsReadOnly="True" ElementStyle="{StaticResource DarkGridTextLightStyle}" Width="120"/>
                                    <DataGridTemplateColumn Header="Sheet Number" Width="120">
                                        <DataGridTemplateColumn.CellStyle>
                                            <Style TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource BaseGridCell}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsNameUnique}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                        <Setter Property="ToolTip" Value="Duplicate Sheet Number!"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTemplateColumn.CellStyle>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="2,2">
                                                    <TextBlock Text="{Binding OriginalNumber}" Foreground="{DynamicResource TextLightBrush}" TextDecorations="Strikethrough" FontSize="10" Margin="2,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Action}" Value="MATCHED">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Action}" Value="CREATE">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox Text="{Binding SheetNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Padding="2,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <!-- Combobox for Name Suggestions -->
                                    <DataGridTemplateColumn Header="Sheet Name" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center" Margin="0,2">
                                                    <TextBlock Text="{Binding OriginalName}" Foreground="{DynamicResource TextLightBrush}" TextDecorations="Strikethrough" FontSize="10" Margin="2,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Action}" Value="MATCHED">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Action}" Value="CREATE">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ComboBox IsEditable="True" Text="{Binding SheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding AvailableNames}" Margin="2,0" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    
                                    <DataGridTemplateColumn Header="Tools" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="Undo" Command="{Binding UndoCommand}" Padding="5,0" Margin="2,0" Background="{DynamicResource ButtonBrush}" BorderBrush="{DynamicResource TextLightBrush}" BorderThickness="1" Foreground="{DynamicResource TextBrush}"/>
                                                    <Button Content="Purge" Command="{Binding PurgeCommand}" Padding="5,0" Margin="2,0" Background="{DynamicResource ButtonBrush}" BorderBrush="{DynamicResource ErrorTextBrush}" BorderThickness="1" Foreground="{DynamicResource ErrorTextBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>

                                <!-- Nested DataGrid for Views on Sheet -->
                                <DataGrid.RowDetailsTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ControlBrush}" Margin="30,0,0,0" Padding="10">
                                            <StackPanel>
                                                <TextBlock Text="Views Placed on Sheet:" FontWeight="SemiBold" Foreground="{DynamicResource TextLightBrush}" Margin="0,0,0,5"/>
                                            <!-- ItemsControl replacing Nested DataGrid for extreme stability -->
                                            <ItemsControl ItemsSource="{Binding Views}" Margin="0,5,0,5">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <Grid Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="200"/>
                                                                    <ColumnDefinition Width="100"/>
                                                                    <ColumnDefinition Width="100"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <ComboBox Grid.Column="0" ItemsSource="{Binding DataContext.UnplacedViews, RelativeSource={RelativeSource AncestorType=Window}}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding SourceViewId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Visibility="{Binding IsNewView, Converter={StaticResource BoolToVis}}" />
                                                                
                                                                <ComboBox Grid.Column="1" IsEditable="True" Text="{Binding ViewType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Visibility="{Binding IsCreateNewMode, Converter={StaticResource BoolToVis}}">
                                                                    <ComboBoxItem Content="FloorPlan"/>
                                                                    <ComboBoxItem Content="CeilingPlan"/>
                                                                    <ComboBoxItem Content="Section"/>
                                                                    <ComboBoxItem Content="Elevation"/>
                                                                    <ComboBoxItem Content="DraftingView"/>
                                                                    <ComboBoxItem Content="ThreeD"/>
                                                                </ComboBox>
                                                                
                                                                <ComboBox Grid.Column="2" IsEditable="True" Text="{Binding Scale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Visibility="{Binding IsCreateNewMode, Converter={StaticResource BoolToVis}}">
                                                                    <ComboBoxItem Content="1/16&quot; = 1'-0&quot;"/>
                                                                    <ComboBoxItem Content="1/8&quot; = 1'-0&quot;"/>
                                                                    <ComboBoxItem Content="1/4&quot; = 1'-0&quot;"/>
                                                                    <ComboBoxItem Content="1/2&quot; = 1'-0&quot;"/>
                                                                    <ComboBoxItem Content="1&quot; = 1'-0&quot;"/>
                                                                </ComboBox>
                                                                
                                                                <ComboBox Grid.Column="3" IsEditable="True" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding DataContext.AvailableNames, RelativeSource={RelativeSource AncestorType=ItemsControl}}" VerticalContentAlignment="Center" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
                                                            </Grid>
                                                            <TextBlock Text="{Binding ValidationWarning}" Foreground="{DynamicResource ErrorTextBrush}" FontSize="11" Margin="405,0,0,2">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ValidationWarning}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                                <Button Content="+ Add View to Sheet" Command="{Binding AddViewCommand}" HorizontalAlignment="Left" Padding="10,2" Margin="0,5,0,0" Background="{DynamicResource ButtonBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGrid.RowDetailsTemplate>
                            </DataGrid>

                            <!-- Editor Footer Actions -->
                            <Border Grid.Row="3" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="5">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                    <Button Name="Btn_ExpandEditor" Content="Expand All Cards" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="11" Padding="5,2"/>
                                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" VerticalAlignment="Center" Margin="5,0"/>
                                    <Button Name="Btn_CollapseEditor" Content="Collapse All Cards" Background="Transparent" Foreground="{DynamicResource AccentBrush}" FontSize="11" Padding="5,2"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Grid>
                </TabItem>

                </TabControl>

            <!-- Reviewer Footer (Only visible when Syncing is relevant) -->
            <Border Name="FooterBorder" Grid.Row="2" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Name="Txt_Status" Grid.Column="0" Text="Ready" VerticalAlignment="Center" Foreground="{DynamicResource TextLightBrush}" FontWeight="SemiBold"/>
                    
                    <Button Name="Btn_Push" Grid.Column="2" Content="Push To Revit" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Bold" FontSize="14" Padding="30,8" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- Resizing Grips (Thumbs) -->
            <Thumb Name="ResizeTop" Style="{StaticResource InvisibleThumbStyle}" Height="5" VerticalAlignment="Top" Cursor="SizeNS" Grid.RowSpan="3" Panel.ZIndex="99"/>
            <Thumb Name="ResizeBottom" Style="{StaticResource InvisibleThumbStyle}" Height="5" VerticalAlignment="Bottom" Cursor="SizeNS" Grid.RowSpan="3" Panel.ZIndex="99"/>
            <Thumb Name="ResizeLeft" Style="{StaticResource InvisibleThumbStyle}" Width="5" HorizontalAlignment="Left" Cursor="SizeWE" Grid.RowSpan="3" Panel.ZIndex="99"/>
            <Thumb Name="ResizeRight" Style="{StaticResource InvisibleThumbStyle}" Width="5" HorizontalAlignment="Right" Cursor="SizeWE" Grid.RowSpan="3" Panel.ZIndex="99"/>
            
            <Thumb Name="ResizeTopLeft" Style="{StaticResource InvisibleThumbStyle}" Width="7" Height="7" VerticalAlignment="Top" HorizontalAlignment="Left" Cursor="SizeNWSE" Grid.RowSpan="3" Panel.ZIndex="100"/>
