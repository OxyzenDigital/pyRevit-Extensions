<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Naming Schemes Editor" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Text="1. Naming Schemes" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextBrush}" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10"/>
        <TextBlock Text="2. Segments (Order matters)" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextBrush}" Grid.Row="0" Grid.Column="2" Margin="0,0,0,10"/>
        
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ListBox Name="List_Schemes" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" FontSize="14" Padding="5"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Name="Btn_AddScheme" Content="+ Add" Width="60" Height="25" Margin="0,0,5,0" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
                <Button Name="Btn_RemoveScheme" Content="- Remove" Width="70" Height="25" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>
        </Grid>
        
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ListBox Name="List_Segments" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="{DynamicResource ControlBrush}" Foreground="{DynamicResource TextBrush}" FontSize="14" Padding="5"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Name="Btn_AddSegment" Content="+ Add" Width="60" Height="25" Margin="0,0,5,0" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
                <Button Name="Btn_RemoveSegment" Content="- Remove" Width="70" Height="25" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
            </StackPanel>
        </Grid>
        
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Name="Btn_Save" Content="Save to Project" Width="140" Height="35" Margin="0,0,10,0" Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Name="Btn_Cancel" Content="Cancel" Width="80" Height="35" Background="{DynamicResource ButtonBrush}" Foreground="{DynamicResource TextBrush}"/>
        </StackPanel>
    </Grid>
</Window>
